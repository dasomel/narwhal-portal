# Dev image — Next.js HMR inside cluster for Skaffold file sync
# ── digest pin (운영 배포 필수) ──────────────────────────────────
# 아직 미고정 상태. 운영 배포 전 아래 명령으로 digest 확인 후 이 줄을 교체:
#
#   docker pull node:22-alpine
#   docker images --digests node | grep 22-alpine
#   FROM node:22-alpine@sha256:<64자 hex digest> AS base
# ─────────────────────────────────────────────────────────────────
FROM node:22-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
# C-4: NODE_TLS_REJECT_UNAUTHORIZED=0 제거 → CA 인증서 경로로 대체
# 인증서는 k8s Secret(narwhal-root-ca-secret)을 /app/certs 에 volumeMount 하거나
# Skaffold kaniko volumeMount 후 COPY 로 주입할 것.
ENV NODE_EXTRA_CA_CERTS=/app/certs/narwhal-ca.crt
ENV NEXT_TELEMETRY_DISABLED=1
RUN corepack enable && apk add --no-cache bash

# ── digest pin (운영 배포 필수) ──────────────────────────────────
# 아직 미고정 상태. 운영 배포 전 아래 명령으로 digest 확인 후 교체:
#
#   docker pull oven/bun:1.3.13-alpine
#   docker images --digests oven/bun | grep 1.3.13-alpine
#   FROM oven/bun:1.3.13-alpine@sha256:<digest> AS bun-source
# ─────────────────────────────────────────────────────────────────
FROM oven/bun:1.3.13-alpine AS bun-source

FROM base
COPY --from=bun-source /usr/local/bin/bun /usr/local/bin/bun
WORKDIR /app

# H-10: 비권한 사용자 생성
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs

COPY package.json bun.lock* pnpm-lock.yaml* ./
RUN if [ -f bun.lock ]; then bun install --frozen-lockfile; \
    else pnpm install --frozen-lockfile; fi

# H-10: 파일 소유권 nextjs:nodejs 로 설정
COPY --chown=nextjs:nodejs . .

# /app itself is created by WORKDIR as root; make it (and .next) writable by nextjs
# so `next dev` can create /app/.next/dev at runtime under the non-root user.
RUN mkdir -p /app/.next && chown -R nextjs:nodejs /app

USER nextjs

EXPOSE 3000 9229

# H-10: HEALTHCHECK — 컨테이너 헬스 확인
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD wget -qO- http://localhost:3000/ > /dev/null || exit 1

# next dev는 Node 런타임으로 실행 (bun run = node 호출). bun이 Next.js dev 시작 빠르게.
CMD ["sh", "-c", "if [ -f bun.lock ]; then bun run dev; else pnpm dev; fi"]
